---
import { buildSeo } from "../utils/seo";

const {
  title,
  description,
  currentPath,
  socialImage,
  socialImageAlt,
  ogType,
} = Astro.props;
const year = new Date().getFullYear();
const seo = buildSeo({
  currentPath: currentPath ?? Astro.url.pathname,
  siteUrl: Astro.site ?? new URL("https://lightscamerateach.com"),
  siteName: "Lights Camera Teach",
  socialImage,
  socialImageAlt,
  defaultSocialImage: "/assets/lights-camera-teach-logo.png",
  defaultSocialImageAlt: "Lights Camera Teach logo",
  ogType,
});
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={seo.canonicalUrl} />
    <meta property="og:type" content={seo.ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={seo.canonicalUrl} />
    <meta property="og:site_name" content={seo.siteName} />
    {seo.socialImageUrl && <meta property="og:image" content={seo.socialImageUrl} />}
    {seo.socialImageAlt && <meta property="og:image:alt" content={seo.socialImageAlt} />}
    <meta name="twitter:card" content={seo.twitterCard} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {seo.socialImageUrl && <meta name="twitter:image" content={seo.socialImageUrl} />}
    {seo.socialImageAlt && <meta name="twitter:image:alt" content={seo.socialImageAlt} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Karla:wght@400;500;600&family=Space+Mono:wght@400;700&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" href="/favicon-32x32.png" type="image/png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" type="image/png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#f9f5ef" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121113" media="(prefers-color-scheme: dark)" />
    <link rel="stylesheet" href="/assets/styles.css" />
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a href="/" class="brand">
          <img
            src="/assets/lights-camera-teach-logo-transparent.png"
            alt="Lights, Camera, Teach logo"
            class="brand-logo"
          />
          <span class="brand-title">Lights, Camera, Teach</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/">Home</a>
          <a href="/about/">About</a>
          <a href="/#lessons">Lessons</a>
          <a href="/#contact">Contact</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="container">
        <div>Lights Camera Teach &mdash; travel-rooted learning.</div>
        <div>&copy; {year} M.E. MacDonald</div>
      </div>
    </footer>
  </body>
</html>
