---
import BaseLayout from "../layouts/BaseLayout.astro";
import { withBase } from "../utils/url";
---

<BaseLayout
  title="Page not found"
  description="The page you were looking for is not available at this address."
>
  <div class="error-page">
    <section class="error-shell">
      <span class="error-kicker">404</span>

      <a class="error-logo" href={withBase("/")}>
        <img src={withBase("/assets/lights-camera-teach-logo-transparent.png")} alt="Lights Camera Teach" />
      </a>

      <h1 class="error-title">Sorry, that page is missing.</h1>
      <p class="error-lede">
        The link may be out of date, the address may have a typo, or the page may have moved.
      </p>

      <div class="error-actions">
        <a class="button" href={withBase("/")}>Go home</a>
        <a class="button secondary" href={withBase("/posts/")}>Read posts</a>
        <a class="button secondary" href={withBase("/about/")}>About</a>
      </div>

      <div class="error-help">
        <p>Here are a few good next steps:</p>
        <ul>
          <li>Check the address for a typo.</li>
          <li>Head home or browse recent posts.</li>
          <li>Find lessons and resources on the home page.</li>
        </ul>
      </div>
    </section>
  </div>
</BaseLayout>
